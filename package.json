{
  "name": "openapi-testgen",
  "version": "1.0.0",
  "description": "A CLI tool that ingests an OpenAPI/Swagger spec and automatically generates test stubs — so you never have to hand-write boilerplate test files again.",
  "main": "dist/cli.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "test": "vitest run"
  },
    "vitest": {
    "include": ["tests/**/*.test.ts"]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ckang21/openapi-testgen.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/ckang21/openapi-testgen/issues"
  },
  "homepage": "https://github.com/ckang21/openapi-testgen#readme",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/swagger-parser": "^4.0.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "swagger-parser": "^10.0.3"
  }
}
